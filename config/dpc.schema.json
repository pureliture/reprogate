{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dev-ps-cast.dev/schema/dpc.schema.json",
  "title": "dev-ps-cast Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "workspaces",
    "processes",
    "tools",
    "records"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "workspaces": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "branch"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "branch": {
              "type": "string",
              "minLength": 1
            },
            "runtime": {
              "type": "string"
            }
          }
        }
      }
    },
    "processes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "G0",
              "P0",
              "P1",
              "P2",
              "P3",
              "P4",
              "S1",
              "S2",
              "S3",
              "S4",
              "NONE"
            ]
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claude": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "hook_enforcement": {
              "type": "boolean"
            }
          }
        },
        "codex": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "records": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wp_path",
        "adr_path",
        "changelog_path"
      ],
      "properties": {
        "wp_path": {
          "type": "string",
          "minLength": 1
        },
        "adr_path": {
          "type": "string",
          "minLength": 1
        },
        "changelog_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
