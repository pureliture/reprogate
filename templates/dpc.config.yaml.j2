version: "1.0"

project:
  name: "{{ project_name }}"
{{ project_description_block }}

workspaces:
  primary:
    name: "{{ primary_workspace_name }}"
    branch: "{{ primary_branch }}"
{{ primary_runtime_block }}

processes:
  enabled:
{{ enabled_process_lines }}

tools:
  claude:
    enabled: {{ claude_enabled }}
    hook_enforcement: {{ claude_hook_enforcement }}
  codex:
    enabled: {{ codex_enabled }}

records:
  wp_path: "{{ wp_path }}"
  adr_path: "{{ adr_path }}"
  changelog_path: "{{ changelog_path }}"
